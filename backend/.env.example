# --- App ---
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# --- Database (Supabase or Neon, use the async URL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini (fallback when Groq's daily quota is exhausted) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Qdrant Cloud ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=due_diligence

# --- Embeddings ---
# Multilingual (Bangla + English), 384-dim
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

YOUTUBE_API_KEY=
SERPER_API_KEY=
