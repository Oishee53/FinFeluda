{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--host"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend/.venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8000", "--app-dir", "backend"],
      "port": 8000
    }
  ]
}
